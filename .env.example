# Supabase 配置
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 演示账号配置（可选）
VITE_DEMO_EMAIL=admin@llmgateway.com
VITE_DEMO_PASSWORD=your-demo-password

# SOCKS 代理（可选，用于科学上网访问 LLM API）
# 每个供应商也可以单独配置代理
# PROXY_SOCKS_HOST=127.0.0.1
# PROXY_SOCKS_PORT=1080
# PROXY_SOCKS_USER=
# PROXY_SOCKS_PASS=
